+static bool IsExtractFunctionName(const string &name) {
+	return name == "struct_extract" || name == "struct_extract_at" || name == "array_extract" ||
+	       name == "variant_extract";
+}
+
+static bool ContainsExtractFunction(const Expression &expr);
+
+static void CheckExtractChild(const Expression &child, bool *found) {
+	if (*found) {
+		return;
+	}
+	if (ContainsExtractFunction(child)) {
+		*found = true;
+	}
+}
+
+static bool ContainsExtractFunction(const Expression &expr) {
+	if (expr.GetExpressionClass() == ExpressionClass::BOUND_FUNCTION) {
+		auto &func = expr.Cast<BoundFunctionExpression>();
+		if (IsExtractFunctionName(func.function.name)) {
+			return true;
+		}
+	}
+	bool found = false;
+	auto callback = std::bind(&CheckExtractChild, std::placeholders::_1, &found);
+	ExpressionIterator::EnumerateChildren(expr, callback);
+	return found;
+}
