+static void CopyPushdownExtractMetadata(const ColumnIndex &global_index, ColumnIndex &local_index,
+                                        const LogicalType &local_type) {
+	if (!global_index.IsPushdownExtract()) {
+		return;
+	}
+	if (!global_index.HasType()) {
+		return;
+	}
+	if (!global_index.HasChildren()) {
+		return;
+	}
+	if (local_index.ChildIndexCount() != 1) {
+		if (local_index.ChildIndexCount() == 0) {
+			return;
+		}
+		auto &global_child = global_index.GetChildIndex(0);
+		optional_idx match_idx;
+		for (idx_t i = 0; i < local_index.ChildIndexCount(); i++) {
+			auto &local_child = local_index.GetChildIndex(i);
+			if (global_child.HasPrimaryIndex() != local_child.HasPrimaryIndex()) {
+				continue;
+			}
+			if (global_child.HasPrimaryIndex()) {
+				if (local_child.GetPrimaryIndex() == global_child.GetPrimaryIndex()) {
+					match_idx = i;
+					break;
+				}
+			} else if (local_child.GetFieldName() == global_child.GetFieldName()) {
+				match_idx = i;
+				break;
+			}
+		}
+		if (!match_idx.IsValid()) {
+			return;
+		}
+		vector<ColumnIndex> child_indexes;
+		child_indexes.push_back(local_index.GetChildIndex(match_idx.GetIndex()));
+		local_index = ColumnIndex(local_index.GetPrimaryIndex(), std::move(child_indexes));
+	}
+	auto &scan_type = global_index.GetScanType();
+	local_index.SetPushdownExtractType(local_type, &scan_type);
+}
+
+static unique_ptr<Expression> AddStructExtractPath(ClientContext &context, unique_ptr<Expression> expr,
+                                                   const ColumnIndex &global_id) {
+	if (!global_id.IsPushdownExtract()) {
+		return expr;
+	}
+	if (!global_id.HasChildren()) {
+		return expr;
+	}
+	auto index_ptr = &global_id;
+	const LogicalType *type_ptr = &expr->return_type;
+	while (index_ptr->HasChildren()) {
+		if (type_ptr->id() != LogicalTypeId::STRUCT) {
+			return expr;
+		}
+		auto &child_index = index_ptr->GetChildIndex(0);
+		idx_t child_idx;
+		if (child_index.HasPrimaryIndex()) {
+			child_idx = child_index.GetPrimaryIndex();
+		} else {
+			child_idx = StructType::GetChildIndexUnsafe(*type_ptr, child_index.GetFieldName());
+		}
+		auto &child_type = StructType::GetChildType(*type_ptr, child_idx);
+		vector<unique_ptr<Expression>> children;
+		children.push_back(std::move(expr));
+		children.push_back(make_uniq<BoundConstantExpression>(Value::BIGINT(static_cast<int64_t>(child_idx + 1))));
+		auto extract_fun = GetExtractAtFunction();
+		auto bind_data = StructExtractAtFun::GetBindData(child_idx);
+		expr = make_uniq<BoundFunctionExpression>(child_type, std::move(extract_fun), std::move(children),
+		                                          std::move(bind_data));
+		index_ptr = &child_index;
+		type_ptr = &child_type;
+	}
+	if (global_id.HasType()) {
+		auto &target_type = global_id.GetScanType();
+		if (expr->return_type != target_type) {
+			expr = BoundCastExpression::AddCastToType(context, std::move(expr), target_type);
+		}
+	}
+	return expr;
+}
+
+static unique_ptr<TableFilter> MakeExtractExpressionFilter(ClientContext &client_context, const TableFilter &filter,
+                                                           const ColumnIndex &extract_index,
+                                                           const LogicalType &root_type) {
+	auto expr = make_uniq<BoundReferenceExpression>(root_type, 0);
+	auto extract_expr = AddStructExtractPath(client_context, std::move(expr), extract_index);
+	auto filter_expr = filter.ToExpression(*extract_expr);
+	return make_uniq<ExpressionFilter>(std::move(filter_expr));
+}
+
+static unique_ptr<TableFilter> MakePushdownExtractFilter(ClientContext &client_context, const TableFilter &filter,
+                                                         const ColumnIndex &extract_index,
+                                                         const LogicalType &root_type) {
+	if (!extract_index.HasChildren()) {
+		return filter.Copy();
+	}
+	return MakeExtractExpressionFilter(client_context, filter, extract_index, root_type);
+}
+
+static bool TryCreateLocalExtractPath(const ColumnIndex &global_id, const MultiFileIndexMapping &mapping,
+                                      const LogicalType &global_type, ColumnIndex &local_index) {
+	if (!global_id.HasChildren()) {
+		return false;
+	}
+	const ColumnIndex *global_ptr = &global_id;
+	const MultiFileIndexMapping *mapping_ptr = &mapping;
+	const LogicalType *type_ptr = &global_type;
+	ColumnIndex *local_ptr = &local_index;
+	while (global_ptr->HasChildren()) {
+		if (type_ptr->id() != LogicalTypeId::STRUCT) {
+			return false;
+		}
+		auto &child_index = global_ptr->GetChildIndex(0);
+		idx_t global_child_index;
+		if (child_index.HasPrimaryIndex()) {
+			global_child_index = child_index.GetPrimaryIndex();
+		} else {
+			global_child_index = StructType::GetChildIndexUnsafe(*type_ptr, child_index.GetFieldName());
+		}
+		auto child_entry = mapping_ptr->child_mapping.find(MultiFileGlobalIndex(global_child_index));
+		if (child_entry == mapping_ptr->child_mapping.end()) {
+			return false;
+		}
+		auto &child_mapping = *child_entry->second;
+		ColumnIndex local_child(child_mapping.index.GetIndex());
+		local_ptr->AddChildIndex(std::move(local_child));
+		local_ptr = &local_ptr->GetChildIndex(local_ptr->ChildIndexCount() - 1);
+		mapping_ptr = &child_mapping;
+		auto &child_types = StructType::GetChildTypes(*type_ptr);
+		if (global_child_index >= child_types.size()) {
+			return false;
+		}
+		type_ptr = &child_types[global_child_index].second;
+		global_ptr = &child_index;
+	}
+	return local_index.HasChildren();
+}
+
+static optional_idx FindLocalColumnIndex(MultiFileLocalColumnIds<MultiFileLocalColumnId> &column_ids,
+                                         MultiFileLocalColumnId local_id) {
+	for (idx_t i = 0; i < column_ids.size(); i++) {
+		auto local_idx = MultiFileLocalIndex(i);
+		if (column_ids[local_idx].GetId() == local_id.GetId()) {
+			return i;
+		}
+	}
+	return optional_idx();
+}
+
+static void MergeColumnIndexChild(vector<ColumnIndex> &current_children, const ColumnIndex &incoming) {
+	for (auto &child : current_children) {
+		if (child.HasPrimaryIndex() != incoming.HasPrimaryIndex()) {
+			continue;
+		}
+		if (child.HasPrimaryIndex()) {
+			if (child.GetPrimaryIndex() != incoming.GetPrimaryIndex()) {
+				continue;
+			}
+		} else if (child.GetFieldName() != incoming.GetFieldName()) {
+			continue;
+		}
+		if (!incoming.HasChildren()) {
+			child.GetChildIndexesMutable().clear();
+			return;
+		}
+		if (!child.HasChildren()) {
+			child.AddChildIndex(incoming.GetChildIndex(0));
+			return;
+		}
+		D_ASSERT(incoming.ChildIndexCount() == 1);
+		MergeColumnIndexChild(child.GetChildIndexesMutable(), incoming.GetChildIndex(0));
+		return;
+	}
+	current_children.push_back(incoming);
+}
+
+static void MergeColumnIndexPaths(ColumnIndex &current, const ColumnIndex &incoming) {
+	if (!incoming.HasChildren()) {
+		current.GetChildIndexesMutable().clear();
+		return;
+	}
+	if (!current.HasChildren()) {
+		return;
+	}
+	auto &current_children = current.GetChildIndexesMutable();
+	for (auto &child : incoming.GetChildIndexes()) {
+		MergeColumnIndexChild(current_children, child);
+	}
+}
