+void PartitionedCopy::RegisterFlushCallback(FlushCallback callback) {
+	annotated_lock_guard<annotated_mutex> guard(lock);
+	flush_callbacks.push_back(std::move(callback));
+}
+
+void PartitionedCopy::RunFlushCallbacks(Pipeline &pipeline, Event &event, ClientContext &client) {
+	vector<FlushCallback> callbacks;
+	{
+		annotated_lock_guard<annotated_mutex> guard(lock);
+		callbacks = std::move(flush_callbacks);
+	}
+	for (auto &entry : callbacks) {
+		entry(pipeline, event, client);
+	}
+}
