# name: test/sql/metadata/hide_metadata_catalog.test
# description: test that the internal metadata catalog is hidden by default only when METADATA_CATALOG is not explicitly set
# group: [metadata]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{UUID}.db

test-env DATA_PATH {TEST_DIR}

# no explicit METADATA_CATALOG, we hide catalog by default
statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS lake (DATA_PATH '{DATA_PATH}/hide_metadata_default_files')

statement ok
CREATE TABLE lake.test(i INTEGER);

statement ok
INSERT INTO lake.test FROM range(10);

# the metadata catalog does not show up in duckdb_databases()
query I
SELECT count(*) FROM duckdb_databases() WHERE database_name = '__ducklake_metadata_lake';
----
0

# none of the internal ducklake_* tables show up in duckdb_tables()
query I
SELECT count(*) FROM duckdb_tables() WHERE database_name = '__ducklake_metadata_lake';
----
0

# the metadata catalog is also hidden from SHOW ALL TABLES
query I
SELECT count(*) FROM (SHOW ALL TABLES) WHERE database = '__ducklake_metadata_lake';
----
0

# ... and from the information_schema
query I
SELECT count(*) FROM information_schema.tables WHERE table_catalog = '__ducklake_metadata_lake';
----
0

# the user-facing ducklake catalog and its tables remain visible
query III
SELECT table_name, estimated_size, column_count FROM duckdb_tables() WHERE database_name = 'lake';
----
test	10	1

# the metadata catalog remains fully accessible by qualified name
query I
SELECT count(*) > 0 FROM __ducklake_metadata_lake.ducklake_snapshot;
----
true

statement ok
DETACH lake

# explicit METADATA_CATALOG, the metadata catalog is visible
statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS lake (DATA_PATH '{DATA_PATH}/hide_metadata_default_files', METADATA_CATALOG 'ducklake_meta')

query I
SELECT count(*) FROM duckdb_databases() WHERE database_name = 'ducklake_meta';
----
1

# and the internal ducklake_* tables are listed
query I
SELECT count(*) > 0 FROM duckdb_tables() WHERE database_name = 'ducklake_meta';
----
true

statement ok
DETACH lake
