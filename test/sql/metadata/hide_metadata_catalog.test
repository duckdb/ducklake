# name: test/sql/metadata/hide_metadata_catalog.test
# description: test that the internal metadata catalog is hidden from catalog/table listings by default
# group: [metadata]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION __TEST_DIR__/{UUID}.db

test-env DATA_PATH __TEST_DIR__

statement ok
ATTACH 'ducklake:${DUCKLAKE_CONNECTION}' AS lake (DATA_PATH '${DATA_PATH}/hide_metadata_default_files', METADATA_CATALOG 'ducklake_meta')

statement ok
CREATE TABLE lake.test(i INTEGER);

statement ok
INSERT INTO lake.test FROM range(10);

# the metadata catalog does not show up in duckdb_databases()
query I
SELECT count(*) FROM duckdb_databases() WHERE database_name = 'ducklake_meta';
----
0

# none of the internal ducklake_* tables show up in duckdb_tables()
query I
SELECT count(*) FROM duckdb_tables() WHERE database_name = 'ducklake_meta';
----
0

# the metadata catalog is also hidden from SHOW ALL TABLES
query I
SELECT count(*) FROM (SHOW ALL TABLES) WHERE database = 'ducklake_meta';
----
0

# ... and from the information_schema
query I
SELECT count(*) FROM information_schema.tables WHERE table_catalog = 'ducklake_meta';
----
0

# the user-facing ducklake catalog and its tables remain visible
query III
SELECT table_name, estimated_size, column_count FROM duckdb_tables() WHERE database_name = 'lake';
----
test	10	1

# the metadata catalog remains fully accessible by qualified name
query I
SELECT count(*) > 0 FROM ducklake_meta.ducklake_snapshot;
----
true

statement ok
DETACH lake

statement ok
ATTACH 'ducklake:${DUCKLAKE_CONNECTION}' AS lake (DATA_PATH '${DATA_PATH}/hide_metadata_default_files', METADATA_CATALOG 'ducklake_meta', HIDE_METADATA_CATALOG false)

# now the metadata catalog shows up
query I
SELECT count(*) FROM duckdb_databases() WHERE database_name = 'ducklake_meta';
----
1

# and the internal ducklake_* tables are listed
query I
SELECT count(*) > 0 FROM duckdb_tables() WHERE database_name = 'ducklake_meta';
----
true

statement ok
DETACH lake

statement ok
ATTACH 'ducklake:${DUCKLAKE_CONNECTION}' AS lake (DATA_PATH '${DATA_PATH}/hide_metadata_default_files', METADATA_CATALOG 'ducklake_meta', HIDE_METADATA_CATALOG true)

query I
SELECT count(*) FROM duckdb_databases() WHERE database_name = 'ducklake_meta';
----
0

statement ok
DETACH lake
