# name: test/sql/comments/comment_on_view_column_invalid.test
# description: COMMENT ON COLUMN fails for a non-existent view column
# group: [comments]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{UUID}.db

test-env DATA_PATH {TEST_DIR}


statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/ducklake_view_col_comment_bad/')

statement ok
CREATE VIEW ducklake.vbad AS SELECT 1 AS only_col

statement error
COMMENT ON COLUMN ducklake.vbad.nope IS 'x'
----
Binder Error
