# name: test/sql/comments/drop_view_expires_tags.test
# description: Verify DROP VIEW expires associated tags in ducklake_tag
# group: [comments]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION __TEST_DIR__/{UUID}.db

statement ok
ATTACH 'ducklake:${DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '__TEST_DIR__/drop_view_expires_tags/')

statement ok
CREATE VIEW ducklake.v AS SELECT 1

statement ok
COMMENT ON VIEW ducklake.v IS 'my view comment'

# verify the tag is active
query II
SELECT key, value FROM __ducklake_metadata_ducklake.ducklake_tag WHERE end_snapshot IS NULL;
----
comment	my view comment

statement ok
DROP VIEW ducklake.v

# after DROP VIEW, the tag should be expired
query I
SELECT count(*) FROM __ducklake_metadata_ducklake.ducklake_tag WHERE end_snapshot IS NULL;
----
0

query I
SELECT count(*) FROM __ducklake_metadata_ducklake.ducklake_tag WHERE end_snapshot IS NOT NULL;
----
1
