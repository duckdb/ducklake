# name: test/sql/comments/comment_on_view_column_v10.test
# description: COMMENT ON COLUMN for views is rejected on DuckLake 1.0 catalogs
# group: [comments]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{UUID}.db

test-env DATA_PATH {TEST_DIR}


statement ok
SET ducklake_default_version = '1.0'

statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/ducklake_view_col_comment_v10/')

statement ok
CREATE VIEW ducklake.v10 AS SELECT 1 AS c

statement error
COMMENT ON COLUMN ducklake.v10.c IS 'unsupported'
----
DuckLake 1.0 does not support COMMENT ON COLUMN for views

statement ok
DETACH ducklake

statement ok
RESET ducklake_default_version
