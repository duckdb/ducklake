# name: test/sql/comments/rename_view_preserves_comment_in_transaction.test
# description: COMMENT ON VIEW + RENAME inside one transaction must preserve the comment
# group: [comments]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{UUID}.db

statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS dl (DATA_PATH '{TEST_DIR}/rename_view_preserves_comment_in_transaction/')

statement ok
USE dl

statement ok
CREATE TABLE t(i INT)

statement ok
BEGIN

statement ok
CREATE VIEW v AS SELECT * FROM t

statement ok
COMMENT ON VIEW v IS 'view comment'

statement ok
ALTER VIEW v RENAME TO v2

statement ok
COMMIT

query II
SELECT view_name, comment FROM duckdb_views() WHERE view_name = 'v2'
----
v2	view comment
