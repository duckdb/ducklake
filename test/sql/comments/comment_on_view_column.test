# name: test/sql/comments/comment_on_view_column.test
# description: COMMENT ON COLUMN for DuckLake views persists and shows in duckdb_columns()
# group: [comments]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{BASE_TEST_NAME}.db

test-env DATA_PATH {TEST_DIR}


statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/ducklake_view_col_comment_files')

statement ok
CREATE VIEW ducklake.v AS SELECT 1 AS col_a

query I
SELECT count(*) FROM duckdb_columns()
WHERE table_name = 'v' AND column_name = 'col_a' AND schema_name = 'main' AND database_name = 'ducklake' AND comment IS NULL
----
1

statement ok
COMMENT ON COLUMN ducklake.v.col_a IS 'view column note'

query I
SELECT count(*) FROM duckdb_columns()
WHERE table_name = 'v' AND column_name = 'col_a' AND schema_name = 'main' AND database_name = 'ducklake' AND comment = 'view column note'
----
1

statement ok
COMMENT ON COLUMN ducklake.v.COL_A IS 'upper-case update'

query I
SELECT count(*) FROM __ducklake_metadata_ducklake.ducklake_view_column_tag WHERE end_snapshot IS NULL
----
1

query II
SELECT column_name, value FROM __ducklake_metadata_ducklake.ducklake_view_column_tag WHERE end_snapshot IS NULL
----
col_a	upper-case update

statement ok
CREATE VIEW ducklake.va(a1) AS SELECT 1 AS x

statement ok
COMMENT ON COLUMN ducklake.va.a1 IS 'real'

statement error
COMMENT ON COLUMN ducklake.va.x IS 'phantom comment'
----
View "va" does not have a column with name "x"

query I
SELECT count(*) FROM duckdb_columns()
WHERE table_name = 'va' AND column_name = 'a1' AND schema_name = 'main' AND database_name = 'ducklake' AND comment = 'real'
----
1

statement ok
USE memory

statement ok
DETACH ducklake

statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/ducklake_view_col_comment_files')

statement ok
USE ducklake

query I
SELECT count(*) FROM duckdb_columns()
WHERE table_name = 'v' AND column_name = 'col_a' AND schema_name = 'main' AND database_name = 'ducklake' AND comment = 'upper-case update'
----
1

query I
SELECT count(*) FROM duckdb_columns()
WHERE table_name = 'va' AND column_name = 'a1' AND schema_name = 'main' AND database_name = 'ducklake' AND comment = 'real'
----
1
