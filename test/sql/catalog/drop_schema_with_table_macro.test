# name: test/sql/catalog/drop_schema_with_table_macro.test
# description: Test dropping a schema containing a table macro in DuckLake
# group: [catalog]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{UUID}.db

test-env DATA_PATH {TEST_DIR}

statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/ducklake_drop_schema_macro_files')

statement ok
CREATE SCHEMA ducklake.myschema;

statement ok
CREATE MACRO ducklake.myschema.mymacro(x) AS TABLE SELECT x AS col;

statement error
DROP SCHEMA ducklake.myschema;
----
there are entries that depend on it

statement ok
DROP SCHEMA ducklake.myschema CASCADE;

statement error
CREATE TABLE ducklake.myschema.tbl(i INT);
----
not found
