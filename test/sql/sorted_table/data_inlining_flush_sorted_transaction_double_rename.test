# name: test/sql/sorted_table/data_inlining_flush_sorted_transaction_double_rename.test
# description: Test flushing inlined data when a newly-added column is renamed twice (A->B->C) in same transaction
# group: [sorted_table]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION __TEST_DIR__/{UUID}.db

test-env DATA_PATH __TEST_DIR__

statement ok
ATTACH 'ducklake:${DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '${DATA_PATH}/ducklake_inlining_flush_double_rename', DATA_INLINING_ROW_LIMIT 10)

statement ok
CREATE TABLE ducklake.double_rename_test (unique_id INTEGER, sort_key_1 VARCHAR, sort_key_2 VARCHAR);

# Insert data (will be inlined)
statement ok
INSERT INTO ducklake.double_rename_test (unique_id, sort_key_1, sort_key_2)
VALUES
    (0, 'a', 'val0'),
    (1, 'c', 'val1'),
    (2, 'b', 'val2'),
    (3, 'a', 'val3'),
    (4, 'c', 'val4');

# In one transaction: ADD col_a, RENAME col_a->col_b, RENAME col_b->col_c, then flush.
statement ok
BEGIN

statement ok
ALTER TABLE ducklake.double_rename_test ADD COLUMN col_a VARCHAR;

statement ok
ALTER TABLE ducklake.double_rename_test RENAME COLUMN col_a TO col_b;

statement ok
ALTER TABLE ducklake.double_rename_test RENAME COLUMN col_b TO col_c;

statement ok
CALL ducklake_flush_inlined_data('ducklake', table_name => 'double_rename_test');

statement ok
COMMIT

query IIII
FROM ducklake.double_rename_test
SELECT *
ORDER BY sort_key_1, unique_id
----
0	a	val0	NULL
3	a	val3	NULL
2	b	val2	NULL
1	c	val1	NULL
4	c	val4	NULL
