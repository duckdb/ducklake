# name: test/sql/deletion_inlining/test_deletion_inlining_flush_drops_table.test
# description: test that flushing inlined deletion data drops the inlined deletion table
# group: [deletion_inlining]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION __TEST_DIR__/{UUID}.db

test-env DATA_PATH __TEST_DIR__

statement ok
ATTACH 'ducklake:${DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '${DATA_PATH}/test_deletion_inlining_flush_drops_table', DATA_INLINING_ROW_LIMIT 10, METADATA_CATALOG 'ducklake_meta')

statement ok
use ducklake

statement ok
CREATE TABLE t AS SELECT range a FROM range(50);

statement ok
DELETE FROM t WHERE a < 5

query III
SELECT file_id, row_id, begin_snapshot FROM ducklake_meta.ducklake_inlined_delete_1 ORDER BY row_id
----
0	0	2
0	1	2
0	2	2
0	3	2
0	4	2

query I
SELECT COUNT(*) FROM t
----
45

statement ok
CALL ducklake_flush_inlined_data('ducklake')

statement error
SELECT * FROM ducklake_meta.ducklake_inlined_delete_1
----
ducklake_inlined_delete_1

query I
SELECT COUNT(*) FROM t
----
45

query I
SELECT count(*) FROM GLOB('${DATA_PATH}/test_flush_drops_table/**/*-delete.parquet')
----
1

statement ok
DELETE FROM t WHERE a >= 45

query III
SELECT file_id, row_id, begin_snapshot FROM ducklake_meta.ducklake_inlined_delete_1 ORDER BY row_id
----
0	45	4
0	46	4
0	47	4
0	48	4
0	49	4

query I
SELECT COUNT(*) FROM t
----
40

statement ok
CALL ducklake_flush_inlined_data('ducklake')

statement error
SELECT * FROM ducklake_meta.ducklake_inlined_delete_1
----
ducklake_inlined_delete_1

query I
SELECT COUNT(*) FROM t
----
40
