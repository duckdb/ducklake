# name: test/sql/general/generated_columns.test
# description: Test generated columns in ducklake
# group: [general]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{UUID}.db

test-env DATA_PATH {TEST_DIR}


statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/ducklake_generated')

statement error
CREATE TABLE ducklake.t0(c0 INT AS (1), c1 INT);
