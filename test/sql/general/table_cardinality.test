# name: test/sql/general/table_cardinality.test
# description: test estimated_size/cardinality for tables created via CREATE TABLE vs CTAS
# group: [general]

require ducklake

require parquet

statement ok
ATTACH 'ducklake:__TEST_DIR__/ducklake.db' AS ducklake (DATA_PATH '__TEST_DIR__/ducklake_files', METADATA_CATALOG 'ducklake_meta')

statement ok
CREATE TABLE ducklake.ctas_table AS FROM range(10000)

query I
SELECT estimated_size FROM duckdb_tables() WHERE table_name = 'ctas_table'
----
10000

statement ok
CREATE TABLE ducklake.empty_table (i INTEGER);

query I
SELECT estimated_size FROM duckdb_tables() WHERE table_name = 'empty_table'
----
0

statement ok
INSERT INTO ducklake.empty_table VALUES (1), (2), (3);

query I
SELECT estimated_size FROM duckdb_tables() WHERE table_name = 'empty_table'
----
3
