# name: test/sql/default/add_column_default_stats_edges.test
# description: ADD COLUMN DEFAULT stats for non-INT types (VARCHAR/DATE/DECIMAL) and empty-table edge case
# group: [default]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION __TEST_DIR__/{UUID}.db

test-env DATA_PATH __TEST_DIR__

statement ok
ATTACH 'ducklake:${DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '${DATA_PATH}/add_column_default_stats_edges_files', METADATA_CATALOG 'ducklake_meta', DATA_INLINING_ROW_LIMIT 100)

# ============================================
# VARCHAR default merged with a later explicit insert.
# Expect min='aaa', max='hello'. Currently returns NULL/NULL.
# ============================================

statement ok
CREATE TABLE ducklake.t_str (a INT)

statement ok
BEGIN

statement ok
INSERT INTO ducklake.t_str VALUES (1), (2), (3)

statement ok
ALTER TABLE ducklake.t_str ADD COLUMN s VARCHAR DEFAULT 'hello'

statement ok
INSERT INTO ducklake.t_str VALUES (4, 'aaa')

statement ok
COMMIT

query II
SELECT min_value, max_value
FROM ducklake_meta.ducklake_table_column_stats s
JOIN ducklake_meta.ducklake_column c USING (table_id, column_id)
JOIN ducklake_meta.ducklake_table t USING (table_id)
WHERE t.table_name = 't_str' AND c.column_name = 's' AND c.end_snapshot IS NULL AND t.end_snapshot IS NULL
----
aaa	hello

# ============================================
# DATE default merged with a later explicit insert.
# Expect min='2020-01-01', max='2024-06-15'. Currently returns NULL/NULL.
# ============================================

statement ok
CREATE TABLE ducklake.t_date (a INT)

statement ok
BEGIN

statement ok
INSERT INTO ducklake.t_date VALUES (1), (2)

statement ok
ALTER TABLE ducklake.t_date ADD COLUMN d DATE DEFAULT '2024-06-15'

statement ok
INSERT INTO ducklake.t_date VALUES (3, DATE '2020-01-01')

statement ok
COMMIT

query II
SELECT min_value, max_value
FROM ducklake_meta.ducklake_table_column_stats s
JOIN ducklake_meta.ducklake_column c USING (table_id, column_id)
JOIN ducklake_meta.ducklake_table t USING (table_id)
WHERE t.table_name = 't_date' AND c.column_name = 'd' AND c.end_snapshot IS NULL AND t.end_snapshot IS NULL
----
2020-01-01	2024-06-15

# ============================================
# DECIMAL default merged with a later explicit insert.
# Expect min='12.34', max='99.99'. Currently returns NULL/NULL.
# ============================================

statement ok
CREATE TABLE ducklake.t_dec (a INT)

statement ok
BEGIN

statement ok
INSERT INTO ducklake.t_dec VALUES (1), (2)

statement ok
ALTER TABLE ducklake.t_dec ADD COLUMN d DECIMAL(10,2) DEFAULT 12.34

statement ok
INSERT INTO ducklake.t_dec VALUES (3, 99.99)

statement ok
COMMIT

query II
SELECT min_value, max_value
FROM ducklake_meta.ducklake_table_column_stats s
JOIN ducklake_meta.ducklake_column c USING (table_id, column_id)
JOIN ducklake_meta.ducklake_table t USING (table_id)
WHERE t.table_name = 't_dec' AND c.column_name = 'd' AND c.end_snapshot IS NULL AND t.end_snapshot IS NULL
----
12.34	99.99

# ============================================
# Empty-table edge case: ADD COLUMN DEFAULT on a zero-row table, then INSERT.
# Only the inserted row's value (7) should drive min/max — a buggy implementation
# that fabricates min=5 from the default on an empty table would regress this.
# This currently PASSES — included as a regression guard.
# ============================================

statement ok
CREATE TABLE ducklake.t_empty (a INT)

statement ok
BEGIN

statement ok
ALTER TABLE ducklake.t_empty ADD COLUMN b INT DEFAULT 5

statement ok
INSERT INTO ducklake.t_empty VALUES (1, 7)

statement ok
COMMIT

query II
SELECT min_value, max_value
FROM ducklake_meta.ducklake_table_column_stats s
JOIN ducklake_meta.ducklake_column c USING (table_id, column_id)
JOIN ducklake_meta.ducklake_table t USING (table_id)
WHERE t.table_name = 't_empty' AND c.column_name = 'b' AND c.end_snapshot IS NULL AND t.end_snapshot IS NULL
----
7	7
