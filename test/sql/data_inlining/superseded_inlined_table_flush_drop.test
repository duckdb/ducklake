# name: test/sql/data_inlining/superseded_inlined_table_flush_drop.test
# description: A superseded inlined-data table must be dropped once it is empty after a flush
# group: [data_inlining]


require ducklake

require parquet

test-env DUCKLAKE_CONNECTION __TEST_DIR__/{UUID}.db

test-env DATA_PATH __TEST_DIR__

statement ok
ATTACH 'ducklake:${DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '${DATA_PATH}/superseded_inlined_flush', METADATA_CATALOG 'ducklake_meta', DATA_INLINING_ROW_LIMIT 10)

statement ok
CREATE TABLE ducklake.t1(i INTEGER)

# inlined at schema version 1
statement ok
INSERT INTO ducklake.t1 VALUES (1), (2), (3)

# bump the schema version; the next inline goes to a new inlined table, superseding version 1
statement ok
ALTER TABLE ducklake.t1 ADD COLUMN j INTEGER

statement ok
INSERT INTO ducklake.t1 VALUES (4, 40)

# two inlined-data tables exist (versions 1 and 2), version 1 is now superseded
query II
SELECT table_id, schema_version FROM ducklake_meta.ducklake_inlined_data_tables ORDER BY ALL
----
1	1
1	2

statement ok
CALL ducklake_flush_inlined_data('ducklake')

# the superseded (now empty) version-1 table is dropped; the current version-2 table stays
query II
SELECT table_id, schema_version FROM ducklake_meta.ducklake_inlined_data_tables ORDER BY ALL
----
1	2

# all rows survive the flush
query II
SELECT i, j FROM ducklake.t1 ORDER BY i
----
1	NULL
2	NULL
3	NULL
4	40
