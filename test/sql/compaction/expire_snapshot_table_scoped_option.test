# name: test/sql/compaction/expire_snapshot_table_scoped_option.test
# description: expire_older_than / delete_older_than can only be set globally, not per schema/table
# group: [compaction]

require ducklake

require parquet

require icu

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{UUID}.db

test-env DATA_PATH {TEST_DIR}

statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/expire_snapshot_table_scoped_option')

statement ok
CREATE TABLE ducklake.test(i INTEGER)

statement ok
INSERT INTO ducklake.test FROM range(10)

statement error
CALL ducklake.set_option('expire_older_than', '1 millisecond', table_name => 'test')
----
can only be set globally

statement error
CALL ducklake.set_option('expire_older_than', '1 millisecond', schema => 'main')
----
can only be set globally

statement error
CALL ducklake.set_option('delete_older_than', '1 millisecond', table_name => 'test')
----
can only be set globally

statement ok
CALL ducklake.set_option('expire_older_than', '1 millisecond')

query I
SELECT count(*) FROM ducklake_expire_snapshots('ducklake', dry_run => true)
----
2
