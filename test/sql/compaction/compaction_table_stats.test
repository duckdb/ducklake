statement ok
INSERT INTO rewrite_zero_output_stats SELECT i::INTEGER FROM range(20) t(i);

statement ok
DELETE FROM rewrite_zero_output_stats WHERE i < 20;

statement ok
CALL ducklake_flush_inlined_data('ducklake');

