# name: test/sql/compaction/compaction_match_partitioning_simple.test
# description: Simple test for match_current_partitioning feature. Verifies that files are repartitioned correctly on disk.
#
# This is a simplified test that avoids the metadata and function return value issues,
# focusing on verifying the core functionality: partitioned files are created
# in the correct directory structure with correct row IDs.
#
# group: [compaction]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION __TEST_DIR__/{UUID}.db

test-env DATA_PATH __TEST_DIR__


# ============================================================================
# Test: Repartitioning with identity partition (DATE column)
# ============================================================================
statement ok
ATTACH 'ducklake:${DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '${DATA_PATH}/ducklake_simple_test', METADATA_CATALOG 'ducklake_metadata')

statement ok
CREATE TABLE ducklake.users(id INTEGER, date DATE, value INTEGER)

# Insert data before partitioning (creates unpartitioned files)
statement ok
INSERT INTO ducklake.users VALUES (1, '2025-01-01'::DATE, 100);
CALL ducklake_flush_inlined_data('ducklake');

statement ok
INSERT INTO ducklake.users VALUES (2, '2025-01-02'::DATE, 200);
CALL ducklake_flush_inlined_data('ducklake');

statement ok
INSERT INTO ducklake.users VALUES (3, '2025-01-03'::DATE, 300);
CALL ducklake_flush_inlined_data('ducklake');

# Add partitioning to table
statement ok
ALTER TABLE ducklake.users SET PARTITIONED BY (date);

# Verify data before merge
query III
SELECT id, date, value FROM ducklake.users ORDER BY id
----
1	2025-01-01	100
2	2025-01-02	200
3	2025-01-03	300

# Re-partition with match_current_partitioning => true
# This should create 3 files in date=YYYY-MM-DD/ directories
query III
SELECT table_name, files_processed, files_created FROM ducklake_merge_adjacent_files('ducklake', 'users', match_current_partitioning => true) ORDER BY ALL
----
users	3	3

# Verify repartitioned files exist on disk
query I
SELECT COUNT(*) FROM GLOB('${DATA_PATH}/ducklake_simple_test/**/*.parquet')
----
6

# Verify partitioned files are in correct directories
query I
SELECT COUNT(*) FROM GLOB('${DATA_PATH}/ducklake_simple_test/**/date=*/*.parquet')
----
3

# Verify row IDs are preserved
query III
SELECT id, date, value FROM ducklake.users ORDER BY id
----
1	2025-01-01	100
2	2025-01-02	200
3	2025-01-03	300
