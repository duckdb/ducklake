# name: test/sql/compaction/merge_adjacent_after_drop_table.test
# description: test that dropping a table properly marks data files and doesn't break compaction
# group: [compaction]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION __TEST_DIR__/{UUID}.db

test-env DATA_PATH __TEST_DIR__

statement ok
ATTACH 'ducklake:${DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '${DATA_PATH}/merge_after_drop_files', METADATA_CATALOG 'ducklake_meta')

statement ok
CREATE TABLE ducklake.alive(j INTEGER)

statement ok
CREATE TABLE ducklake.dead(i INTEGER)

# insert data into the table that will be dropped, creating multiple small files
statement ok
INSERT INTO ducklake.dead VALUES (1)

statement ok
CALL ducklake_flush_inlined_data('ducklake')

statement ok
INSERT INTO ducklake.dead VALUES (2)

statement ok
CALL ducklake_flush_inlined_data('ducklake')

statement ok
INSERT INTO ducklake.dead VALUES (3)

statement ok
CALL ducklake_flush_inlined_data('ducklake')

# insert data into the alive table too
statement ok
INSERT INTO ducklake.alive VALUES (100)

statement ok
CALL ducklake_flush_inlined_data('ducklake')

statement ok
INSERT INTO ducklake.alive VALUES (200)

statement ok
CALL ducklake_flush_inlined_data('ducklake')

# verify data files exist for both tables
query I
SELECT COUNT(*) FROM ducklake_meta.ducklake_data_file WHERE end_snapshot IS NULL
----
5

# drop the table
statement ok
DROP TABLE ducklake.dead

# verify that dropped table's data files have end_snapshot set (not orphaned)
# this is the core of the bug: if end_snapshot is NOT set, files become orphaned
query I
SELECT COUNT(*) FROM ducklake_meta.ducklake_data_file WHERE end_snapshot IS NULL
----
2

# verify only the alive table's files remain active
query I
SELECT COUNT(*) FROM ducklake_meta.ducklake_data_file d
JOIN ducklake_meta.ducklake_table t ON d.table_id = t.table_id
WHERE d.end_snapshot IS NULL AND t.table_name = 'alive'
----
2

# verify all dead table's files are properly closed out
query I
SELECT COUNT(*) FROM ducklake_meta.ducklake_data_file d
JOIN ducklake_meta.ducklake_table t ON d.table_id = t.table_id
WHERE d.end_snapshot IS NOT NULL AND t.table_name = 'dead'
----
3

# merge_adjacent_files should not crash
query IIII
SELECT * FROM ducklake_merge_adjacent_files('ducklake')
----
main	alive	2	1

# checkpoint should not crash
statement ok
CHECKPOINT ducklake

# alive table should still be readable
query I
SELECT * FROM ducklake.alive ORDER BY j
----
100
200
