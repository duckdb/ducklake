# name: test/sql/delete/parquet_deletion_describe.test
# description: Validate the on-disk parquet delete-file structure/contents produced by flushing inlined deletions (parquet-format specific; skipped under deletion vectors). Mirrors the parquet reads removed from test/sql/deletion_inlining/*
# group: [delete]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{UUID}.db

test-env DATA_PATH {TEST_DIR}

statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/parquet_del', DATA_INLINING_ROW_LIMIT 10)

statement ok
USE ducklake

# ── single flushed deletion: schema + contents ──
statement ok
CREATE TABLE t1 (a INTEGER)

statement ok
INSERT INTO t1 VALUES (1), (2), (3);

statement ok
DELETE FROM t1 WHERE a = 2;

statement ok
CALL ducklake_flush_inlined_data('ducklake')

# the flushed delete file is a parquet with iceberg-style file_path/pos plus the ducklake snapshot column
query II
SELECT column_name, column_type FROM (DESCRIBE SELECT * FROM '{DATA_PATH}/parquet_del/main/t1/*-delete.parquet') ORDER BY column_name
----
_ducklake_internal_snapshot_id	BIGINT
file_path	VARCHAR
pos	BIGINT

query II
SELECT pos, _ducklake_internal_snapshot_id FROM '{DATA_PATH}/parquet_del/main/t1/*-delete.parquet'
----
1	3

# ── deletes over multiple snapshots, each position keeps its own delete snapshot ──
statement ok
CREATE TABLE t2 (a INTEGER)

statement ok
INSERT INTO t2 VALUES (1), (2), (3), (1), (2), (3), (5), (6);

statement ok
DELETE FROM t2 WHERE a = 2;

statement ok
DELETE FROM t2 WHERE a = 1;

statement ok
DELETE FROM t2 WHERE a = 5;

statement ok
DELETE FROM t2 WHERE a = 6;

statement ok
CALL ducklake_flush_inlined_data('ducklake');

query II
SELECT pos, _ducklake_internal_snapshot_id FROM '{DATA_PATH}/parquet_del/main/t2/*-delete.parquet'
----
0	8
1	7
3	8
4	7
6	9
7	10
