# name: test/sql/rewrite_data_files/test_rewrite_partition_values.test
# description: test partition_values filter for ducklake_rewrite_data_files
# group: [rewrite_data_files]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{UUID}.db

test-env DATA_PATH {TEST_DIR}

statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/rewrite_partition_values', METADATA_CATALOG 'metadata')

statement ok
USE ducklake

statement ok
CREATE TABLE t(p INTEGER, id INTEGER, v INTEGER);

statement ok
ALTER TABLE t SET PARTITIONED BY (p);

statement ok
INSERT INTO t VALUES (1, 1, 10), (1, 2, 20);

statement ok
CALL ducklake_flush_inlined_data('ducklake')

statement ok
INSERT INTO t VALUES (2, 1, 100), (2, 2, 200);

statement ok
CALL ducklake_flush_inlined_data('ducklake')

statement ok
CREATE TEMP TABLE updates AS
SELECT * FROM (VALUES (1, 1, 15), (2, 1, 150)) AS t(p, id, v);

statement ok
MERGE INTO t
USING updates
ON (t.p = updates.p AND t.id = updates.id)
WHEN MATCHED THEN UPDATE SET v = updates.v;

statement ok
CALL ducklake_flush_inlined_data('ducklake')

query I
SELECT COUNT(*) FROM metadata.ducklake_delete_file WHERE end_snapshot IS NULL
----
2

query III
SELECT table_name, files_processed, files_created
FROM ducklake_rewrite_data_files('ducklake', 't', delete_threshold => 0, partition_values => struct_pack(p := 1))
ORDER BY ALL
----
t	1	1

query I
SELECT COUNT(*) FROM metadata.ducklake_delete_file WHERE end_snapshot IS NULL
----
1

query III
SELECT p, id, v FROM t ORDER BY ALL
----
1	1	15
1	2	20
2	1	150
2	2	200
