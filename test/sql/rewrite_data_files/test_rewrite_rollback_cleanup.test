# name: test/sql/rewrite_data_files/test_rewrite_rollback_cleanup.test
# description: rolling back a rotated rewrite removes its output files, no orphans left on disk
# group: [rewrite_data_files]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{UUID}.db

test-env DATA_PATH {TEST_DIR}

statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS dl (DATA_PATH '{DATA_PATH}/rewrite_rollback', METADATA_CATALOG 'ducklake_metadata', DATA_INLINING_ROW_LIMIT 0)

statement ok
USE dl

statement ok
SET threads TO 1

statement ok
CALL dl.set_option('parquet_compression', 'uncompressed')

statement ok
CALL dl.set_option('target_file_size', '512MB')

statement ok
CREATE TABLE t(id BIGINT, payload VARCHAR);

statement ok
INSERT INTO t SELECT i, repeat(md5(i::VARCHAR), 4) FROM range(20000) t(i)

statement ok
DELETE FROM t WHERE id % 10 = 0

# on disk: one data file + one delete file
query I
SELECT COUNT(*) FROM GLOB('{DATA_PATH}/rewrite_rollback/main/t/*.parquet')
----
2

statement ok
CALL dl.set_option('parquet_row_group_size', '2000')

statement ok
CALL dl.set_option('target_file_size', '64KB')

# run a rotated rewrite inside a transaction, then roll it back
statement ok
BEGIN

statement ok
CALL ducklake_rewrite_data_files('dl', 't', delete_threshold => 0)

statement ok
ROLLBACK

# the 5 rotated output files written during the rewrite must be cleaned up:
# still exactly the original 2 (would be 7 without the rollback cleanup)
query I
SELECT COUNT(*) FROM GLOB('{DATA_PATH}/rewrite_rollback/main/t/*.parquet')
----
2

# the table is untouched by the rolled-back rewrite
query I
SELECT COUNT(*) FROM t
----
18000

# and a fresh rewrite still commits cleanly afterwards
query II
SELECT SUM(files_processed), SUM(files_created) FROM ducklake_rewrite_data_files('dl', 't', delete_threshold => 0)
----
1	5
