# name: test/sql/alter/alter_column_type_stats.test
# description: ALTER COLUMN ... TYPE must not corrupt table-level min/max column stats
# group: [alter]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{UUID}.db

test-env DATA_PATH {TEST_DIR}

statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/alter_column_type_stats_files', METADATA_CATALOG 'ducklake_meta')

statement ok
CREATE TABLE ducklake.t (id INTEGER, v INTEGER)

# batch 1: pre-ALTER rows, v ranges over [1000, 1063]
statement ok
INSERT INTO ducklake.t SELECT i, 1000 + (i % 64) FROM range(4096) t(i)

# sanity: table-level stats for v reflect the pre-ALTER file
query II
SELECT min_value, max_value
FROM ducklake_meta.ducklake_table_column_stats
WHERE table_id = 1 AND column_id = 2
----
1000	1063

# widening retype + insert in one transaction: the merge sees the pre-ALTER (INTEGER)
# min/max and the post-ALTER (BIGINT) file. Pre-fix, MergeStats dropped min/max on the
# type change instead of casting them across.
statement ok
BEGIN

statement ok
ALTER TABLE ducklake.t ALTER COLUMN v TYPE BIGINT

# batch 2: post-ALTER rows, v ranges over [5000, 5063]
statement ok
INSERT INTO ducklake.t SELECT 100000 + i, 5000 + (i % 64) FROM range(4096) t(i)

statement ok
COMMIT

# merged min/max must still span both files (1000..5063); pre-fix they came back NULL
query II
SELECT min_value, max_value
FROM ducklake_meta.ducklake_table_column_stats
WHERE table_id = 1 AND column_id = 2
----
1000	5063

# recorded stats must bound the real min/max
query I
SELECT count(*)
FROM ducklake_meta.ducklake_table_column_stats s
WHERE s.table_id = 1 AND s.column_id = 2
  AND (s.min_value::BIGINT > (SELECT min(v) FROM ducklake.t)
    OR s.max_value::BIGINT < (SELECT max(v) FROM ducklake.t))
----
0

# pre-ALTER rows must still read back their original values
query I
SELECT count(*) FROM ducklake.t WHERE id < 4096 AND v <> 1000 + (id % 64)
----
0

# ============================================
# post-ALTER batch lowers the min: min comes from the new batch (0), max from the
# pre-ALTER batch (1063, cast up) - checks the compare works in both directions
# ============================================

statement ok
CREATE TABLE ducklake.t2 (id INTEGER, v INTEGER)

statement ok
INSERT INTO ducklake.t2 SELECT i, 1000 + (i % 64) FROM range(4096) t(i)

statement ok
BEGIN

statement ok
ALTER TABLE ducklake.t2 ALTER COLUMN v TYPE BIGINT

statement ok
INSERT INTO ducklake.t2 SELECT 100000 + i, (i % 64) FROM range(4096) t(i)

statement ok
COMMIT

query II
SELECT min_value, max_value
FROM ducklake_meta.ducklake_table_column_stats
WHERE table_id = 2 AND column_id = 2
----
0	1063

# ============================================
# a different widening family (DECIMAL precision), not just integers
# ============================================

statement ok
CREATE TABLE ducklake.t3 (id INTEGER, v DECIMAL(9,2))

statement ok
INSERT INTO ducklake.t3 SELECT i, (1000 + (i % 64))::DECIMAL(9,2) FROM range(4096) t(i)

statement ok
BEGIN

statement ok
ALTER TABLE ducklake.t3 ALTER COLUMN v TYPE DECIMAL(18,2)

statement ok
INSERT INTO ducklake.t3 SELECT 100000 + i, (5000 + (i % 64))::DECIMAL(18,2) FROM range(4096) t(i)

statement ok
COMMIT

query II
SELECT min_value, max_value
FROM ducklake_meta.ducklake_table_column_stats
WHERE table_id = 3 AND column_id = 2
----
1000.00	5063.00

# ============================================
# same retype across separate commits (not one transaction) - green today, pinned so
# both commit shapes stay consistent
# ============================================

statement ok
CREATE TABLE ducklake.t4 (id INTEGER, v INTEGER)

statement ok
INSERT INTO ducklake.t4 SELECT i, 1000 + (i % 64) FROM range(4096) t(i)

statement ok
ALTER TABLE ducklake.t4 ALTER COLUMN v TYPE BIGINT

statement ok
INSERT INTO ducklake.t4 SELECT 100000 + i, 5000 + (i % 64) FROM range(4096) t(i)

query II
SELECT min_value, max_value
FROM ducklake_meta.ducklake_table_column_stats
WHERE table_id = 4 AND column_id = 2
----
1000	5063

# ============================================
# FLOAT -> DOUBLE widening: the stored min/max string is not bit-faithful when reparsed as
# DOUBLE (a FLOAT 0.1 widens to 0.10000000149..., not the double nearest "0.1"). Casting it
# across would persist a value-wrong bound, so min/max are discarded for a FLOAT source
# (matching pre-#1308 behavior). Keeping the wrong bound made SELECT max(v) answer from the
# corrupt stat (0.1) instead of the real value (a separate reload-path bug is tracked in #1307).
# ============================================

statement ok
CREATE TABLE ducklake.t5 (v FLOAT)

statement ok
INSERT INTO ducklake.t5 VALUES (0.1)

statement ok
BEGIN

statement ok
ALTER TABLE ducklake.t5 ALTER COLUMN v TYPE DOUBLE

statement ok
INSERT INTO ducklake.t5 VALUES (0.05)

statement ok
COMMIT

# max(v) must be the real widened value, not the corrupt stat bound 0.1 (aggregate pushdown)
query I
SELECT max(v) FROM ducklake.t5
----
0.10000000149011612

# the FLOAT-source min/max must be discarded (NULL), not kept as a value-wrong bound
query II
SELECT min_value, max_value
FROM ducklake_meta.ducklake_table_column_stats
WHERE table_id = 5 AND column_id = 1
----
NULL	NULL

# ============================================
# nested container retype: a STRUCT field widens INTEGER -> BIGINT. Stats live on the leaf
# field (v.a is column_id 3), so the same-transaction merge must cast the leaf min/max across
# just like a scalar column.
# ============================================

statement ok
CREATE TABLE ducklake.t6 (id INTEGER, v STRUCT(a INTEGER))

statement ok
INSERT INTO ducklake.t6 SELECT i, {'a': 1000 + (i % 64)} FROM range(4096) t(i)

statement ok
BEGIN

statement ok
ALTER TABLE ducklake.t6 ALTER COLUMN v TYPE STRUCT(a BIGINT)

statement ok
INSERT INTO ducklake.t6 SELECT 100000 + i, {'a': 5000 + (i % 64)} FROM range(4096) t(i)

statement ok
COMMIT

query II
SELECT min_value, max_value
FROM ducklake_meta.ducklake_table_column_stats
WHERE table_id = 6 AND column_id = 3
----
1000	5063

# ============================================
# temporal widening (DATE -> TIMESTAMP): the other promotable family besides numerics. Both
# are value-comparison types, so min/max must cast across just like the integer ladder.
# ============================================

statement ok
CREATE TABLE ducklake.t7 (v DATE)

statement ok
INSERT INTO ducklake.t7 VALUES (DATE '2020-01-01'), (DATE '2020-12-31')

statement ok
BEGIN

statement ok
ALTER TABLE ducklake.t7 ALTER COLUMN v TYPE TIMESTAMP

statement ok
INSERT INTO ducklake.t7 VALUES (TIMESTAMP '2019-01-01'), (TIMESTAMP '2021-01-01')

statement ok
COMMIT

query II
SELECT min_value, max_value
FROM ducklake_meta.ducklake_table_column_stats
WHERE table_id = 7 AND column_id = 1
----
2019-01-01 00:00:00	2021-01-01 00:00:00
