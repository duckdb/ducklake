# name: test/sql/constraints/unsupported.test
# description: test unsupported constraints
# group: [constraints]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{UUID}.db

test-env DATA_PATH {TEST_DIR}


statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/ducklake_unsupported_files')

statement error
CREATE TABLE ducklake.test(i INTEGER PRIMARY KEY, j INTEGER);
----
not supported

statement error
CREATE TABLE ducklake.test(i INTEGER, j INTEGER,  CHECK (i > j));
----
not supported
