# name: test/sql/stats/filter_pushdown_postgres_index.test
# description: Verify queries over stats with postgres use index if available
# group: [stats]

require ducklake

require parquet

require postgres_scanner

require-env DUCKLAKE_CI

test-env DUCKLAKE_CONNECTION {TEST_DIR}/{UUID}.db

test-env DATA_PATH {TEST_DIR}

statement ok
CALL enable_logging('DuckLakeMetadata', storage='memory', storage_config={'buffer_size': 0})

statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/ducklake_pg_index_files', DATA_INLINING_ROW_LIMIT 0)

statement ok
CREATE TABLE ducklake.t(v INTEGER, i INTEGER);

statement ok
INSERT INTO ducklake.t SELECT i % 1000, i FROM range(0, 1000) tbl(i);

statement ok
INSERT INTO ducklake.t SELECT i % 1000, i FROM range(100000, 101000) tbl(i);

statement ok
INSERT INTO ducklake.t SELECT i % 1000, i FROM range(500000, 501000) tbl(i);

# without the index: falls back to {METADATA_CATALOG}.ducklake_file_column_stats CTE
query I
SELECT COUNT(*) FROM ducklake.t WHERE i > 100998
----
1001

query I
SELECT COUNT(*) FROM ducklake.t WHERE i BETWEEN 500050 AND 500100
----
51

# Create the index
# Re-attach below to refresh the per-manager "no index" cache.
statement ok
CALL postgres_execute('__ducklake_metadata_ducklake', 'CREATE INDEX IF NOT EXISTS idx_fcs_table_col ON public.ducklake_file_column_stats(table_id, column_id)')

statement ok
DETACH ducklake

statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/ducklake_pg_index_files', DATA_INLINING_ROW_LIMIT 0)

# --- with the index: hits the postgres_query() CTE override ---
query I
SELECT COUNT(*) FROM ducklake.t WHERE i > 100998
----
1001

query I
SELECT COUNT(*) FROM ducklake.t WHERE i BETWEEN 500050 AND 500100
----
51

# Verify index was used
query I
SELECT COUNT(*) > 0 FROM duckdb_logs_parsed('DuckLakeMetadata')
WHERE query LIKE '%postgres_query(%' AND query LIKE '%ducklake_file_column_stats%'
  AND query LIKE '%data_file_id%'
----
true

# Drop Index midsession (without re-attach)

statement ok
CALL postgres_execute('__ducklake_metadata_ducklake', 'DROP INDEX IF EXISTS idx_fcs_table_col')

statement ok
CALL truncate_duckdb_logs()

query I
SELECT COUNT(*) FROM ducklake.t WHERE i > 100998
----
1001

query I
SELECT COUNT(*) FROM ducklake.t WHERE i BETWEEN 500050 AND 500100
----
51

# We still use the index-ed query, as attach was not performed, but results are ok
query I
SELECT COUNT(*) > 0 FROM duckdb_logs_parsed('DuckLakeMetadata')
WHERE query LIKE '%postgres_query(%' AND query LIKE '%ducklake_file_column_stats%'
  AND query LIKE '%data_file_id%'
----
true


# DETACH+ATTACH forces the probe to re-run and observe the missing index. After this,
# the file-column-stats CTE drops the postgres_query() wrapper.

statement ok
DETACH ducklake

statement ok
ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/ducklake_pg_index_files', DATA_INLINING_ROW_LIMIT 0)

statement ok
CALL truncate_duckdb_logs()

query I
SELECT COUNT(*) FROM ducklake.t WHERE i > 100998
----
1001

query I
SELECT COUNT(*) FROM ducklake.t WHERE i BETWEEN 500050 AND 500100
----
51

# Fresh attach reprobed and saw no index -- fall back to the standard CTE (no postgres_query() wrapper).
query I
SELECT COUNT(*) FROM duckdb_logs_parsed('DuckLakeMetadata')
WHERE query LIKE '%postgres_query(%' AND query LIKE '%ducklake_file_column_stats%'
  AND query LIKE '%data_file_id%'
----
0
