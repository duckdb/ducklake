# name: test/sql/quack/quack_basic.test
# description: smoke test DuckLake on a quack-backed metadata catalog (RPC self-serve)
# group: [quack]

require httpfs

require ducklake

require parquet

require quack

statement ok
LOAD httpfs;

statement ok
LOAD quack;

statement ok
SELECT * FROM quack_serve('quack://localhost:19999');

statement ok
ATTACH 'ducklake:quack://localhost:19999' AS lake (
    DATA_PATH '__TEST_DIR__/quack_basic_files',
    METADATA_PARAMETERS MAP {'type': 'quack'}
);

statement ok
CREATE TABLE lake.test(i INTEGER, j INTEGER);

query II
SELECT * FROM lake.test
----

statement ok
INSERT INTO lake.test VALUES (1, 2), (NULL, 3);

query II
SELECT * FROM lake.test ORDER BY i NULLS FIRST
----
NULL	3
1	2

query I
SELECT count(*) FROM quack_query('quack://localhost:19999', 'SELECT snapshot_id FROM ducklake_snapshot')
----
3

query I
SELECT table_name FROM quack_query('quack://localhost:19999', 'SELECT table_name FROM ducklake_table')
----
test

statement ok
DETACH lake;

statement ok
SELECT * FROM rpc_stop('quack://localhost:19999');
